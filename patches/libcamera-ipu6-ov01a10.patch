+	/*
+	 * Adapt contrast based on scene brightness. Compute the fraction
+	 * of pixels in the top quarter of the histogram; when the scene
+	 * is mostly bright (backlit), reduce contrast and gamma lift to
+	 * avoid washing out. In normal/dark scenes, boost both.
+	 */
+	const auto &histogram = stats->yHistogram;
+	const unsigned int total =
+		std::accumulate(histogram.begin(), histogram.end(), 0u);
+	const unsigned int topQuarter = SwIspStats::kYHistogramSize / 4;
+	unsigned int brightPixels = 0;
+	for (unsigned int i = SwIspStats::kYHistogramSize - topQuarter;
+	     i < SwIspStats::kYHistogramSize; i++)
+		brightPixels += histogram[i];
+
+	const float brightFraction = total > 0
+		? static_cast<float>(brightPixels) / total : 0.0f;
+
+	/*
+	 * Map bright fraction to contrast: at 0% bright pixels use 1.3,
+	 * at 50%+ bright pixels use 1.0 (neutral). Linear interpolation.
+	 */
+	static constexpr float kContrastMax = 1.3;
+	static constexpr float kContrastMin = 1.0;
+	static constexpr float kBrightThreshold = 0.5;
+	float t = std::min(brightFraction / kBrightThreshold, 1.0f);
+	float adaptiveContrast = kContrastMax - t * (kContrastMax - kContrastMin);
+
+	context.activeState.knobs.contrast = adaptiveContrast;
+
+	metadata.set(controls::Contrast, adaptiveContrast);
 }
 
